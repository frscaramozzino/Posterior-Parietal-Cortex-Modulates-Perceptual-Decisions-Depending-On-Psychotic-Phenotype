    "participant_idx, participant = pd.factorize(data.participant)\n",
    "coords = {\n",
    "    \"participant\": participant,\n",
    "    \"obs_id\": np.arange(len(participant_idx)),\n",
    "}\n",
    "\n",
    "m_conf_bt=data[\"confidence_BT\"].mean()\n",
