   "metadata": {},
   "outputs": [],
   "source": [
    "data = pd.read_csv(\"data_bt_dem.csv\").dropna()\n",
    "data=data[(data['draws']>1)]\n",
    "participantcode = data.participant.unique()\n",
    "\n",
    "data[\"draws\"] = data[\"draws\"].astype(theano.config.floatX)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "443ced87-b097-4ac5-a2db-b8310538bf4a",
   "metadata": {},
   "outputs": [],
   "source": [
    "participant_idx, participant = pd.factorize(data.participant)\n",
    "coords = {\n",
    "    \"participant\": participant,\n",
    "    \"obs_id\": np.arange(len(participant_idx)),\n",
    "}\n",
    "\n",
    "m_conf_bt=data[\"confidence_BT\"].mean()\n",
    "sd_conf_bt=data[\"confidence_BT\"].std()\n",
    "\n",
    "median_dtd=data[\"confidence_BT\"].median()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "9f779817-dacf-468d-9b41-f10e3dcf4009",
   "metadata": {},
   "outputs": [],
   "source": [
    "with pm.Model(coords=coords) as conf_bt_caps:\n",
    "    participant_idx = pm.Data(\"participant_idx\", participant_idx, dims=\"obs_id\")\n",
    "    # Hyperpriors for group nodes\n",
    "    mu_a = pm.Normal(\"mu_a\", mu=m_conf_bt, sigma=0.5)\n",
    "    sigma_a = pm.HalfNormal(\"sigma_a\", sd_conf_bt)\n",
    "    mu_b = pm.Normal(\"mu_b\", mu=0.0, sigma=0.5)\n",
    "    sigma_b = pm.HalfNormal(\"sigma_b\", 0.5)\n",
    "    mu_b_caps = pm.Normal(\"mu_b_caps\", mu=0.0, sigma=0.5)\n",
    "    sigma_b_caps = pm.HalfNormal(\"sigma_b_caps\", 0.5)\n",
    "    \n",
    "\n",
    "    # Intercept for each county, distributed around group mean mu_a\n",
    "    # Above we just set mu and sd to a fixed value while here we\n",
    "    # plug in a common group distribution for all a and b (which are\n",
    "    # vectors of length n_counties).\n",
    "    a = pm.Normal(\"a\", mu=mu_a, sigma=sigma_a, dims=\"participant\")\n",
    "    # effect difference between basement and floor level\n",
    "    b = pm.Normal(\"b\", mu=mu_b, sigma=sigma_b, dims=\"participant\")\n",
    "    b_caps = pm.Normal(\"b_caps\", mu=mu_b_caps, sigma=sigma_b_caps, dims=\"participant\")\n",
    "\n",
    "    # Model error\n",
    "    eps = pm.HalfCauchy(\"eps\", 5.0)\n",
    "\n",
    "    confidence_bt_caps_est = a[participant_idx] + b[participant_idx] * data.session.values+ b_caps[participant_idx] * data.caps.values\n",
    "\n",
    "\n",
    "    # Data likelihood\n",
    "    confidence_bt_caps_like = pm.Normal(\"confidence_bt_caps_like \", mu=confidence_bt_caps_est, sigma=eps, observed=data.confidence_BT, dims=\"obs_id\")\n",
    "    \n",
    "    "
   ]
  },
